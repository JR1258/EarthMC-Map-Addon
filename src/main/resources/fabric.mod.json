{
  "schemaVersion": 1,
  "id": "townymapaddon",
  "version": "${version}",
  "name": "EarthMC Map Addon",
  "description": "Overlays EarthMC Towny town borders and online players on Xaero's WorldMap.",
  "authors": ["JR1258"],
  "contact": {
    "homepage": "https://github.com/JR1258/EarthMC-Map-Addon",
    "sources": "https://github.com/JR1258/EarthMC-Map-Addon",
    "issues": "https://github.com/JR1258/EarthMC-Map-Addon/issues"
  },
  "icon": "assets/townymapaddon/icon.png",
  "license": "Apache-2.0",
  "environment": "client",
  "entrypoints": {
    "client": ["net.townymap.TownyMapMod"],
    "modmenu": ["net.townymap.gui.TownyMapModMenuIntegration"]
  },
  "mixins": [
    "townymapaddon.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api":   "*",
    "minecraft":    "1.21.11"
  },
  "suggests": {
    "xaeroworldmap": "*",
    "xaerosminimap": "*",
    "modmenu":       "*"
  },
  "custom": {
    "modmenu": {
      "update_checker": true
    }
  }
}
